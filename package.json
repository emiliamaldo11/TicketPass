{
  "name": "ticket-pass-project",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "recintosdb": "json-server public/db/recintos.json",
    "eventosdb": "json-server public/db/eventos.json --port 3001",
    "usuariosdb": "json-server public/db/usuarios.json --port 3002",
    "comprasdb": "json-server public/db/compras.json --port 3003",
    "comprasdevueltasdb": "json-server public/db/comprasDevueltas.json --port 3004",
    "soporte": "json-server public/db/preguntasFrecuentes.json --port 3005",
    "start:db": "concurrently \"npm run recintosdb\" \"npm run eventosdb\" \"npm run usuariosdb\" \"npm run comprasdb\" \"npm run comprasdevueltasdb\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/fire": "^18.0.1",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@fortawesome/angular-fontawesome": "^0.15.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "firebase": "^11.10.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "mercadopago": "^2.0.15",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.14.5",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.8",
    "@angular/cli": "^18.2.8",
    "@angular/compiler-cli": "^18.2.0",
    "@types/jasmine": "~5.1.0",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2"
  }
}
